rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate & Denial by Default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none');
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isStaff() {
      return isSignedIn() && getRole() in ['admin', 'staff'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
        && (data.defaultPrice is number || data.defaultPrice is int)
        && (data.get('deleted', false) is bool)
        && (data.get('color', '#10b981') is string);
    }

    function isValidVendor(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200
        && (
             (data.get('categoryIds', []) is list && data.categoryIds.size() >= 0) ||
             (data.get('categoryId', '') is string && data.categoryId.size() < 100)
           )
        && (data.get('proprietor', '') is string && data.get('proprietor', '').size() < 200)
        && (data.totalDue is number || data.totalDue is int)
        && (data.totalPaid is number || data.totalPaid is int)
        && data.status in ['Paid', 'Not Paid', 'Partial', 'Unpaid']
        && (data.get('phone', '') is string && data.get('phone', '').size() < 40)
        && (data.get('photo', '') is string && data.get('photo', '').size() < 10000001)
        && (data.get('qrCode', '') is string && data.get('qrCode', '').size() < 128)
        && (data.get('categoryNames', []) is list)
        && (data.get('lastPaymentDate', '') is string || data.get('lastPaymentDate', request.time) is timestamp);
    }

    function isValidWorker(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200
        && data.role is string && data.role.size() > 0 && data.role.size() < 100
        && (data.get('qrCode', '') is string && data.get('qrCode', '').size() < 128)
        && (data.get('phone', '') is string && data.get('phone', '').size() < 40)
        && (data.get('photo', '') is string && data.get('photo', '').size() < 10000001)
        && (data.get('vendorId', '') is string && data.get('vendorId', '').size() < 128)
        && (data.get('vendorName', '') is string && data.get('vendorName', '').size() < 200)
        && (data.createdAt is string || data.createdAt is timestamp)
        && (data.get('deleted', false) is bool);
    }

    function isValidPayment(data) {
      return data.vendorId is string && data.vendorId.size() < 128
        && (data.amount is number || data.amount is int) && data.amount > 0
        && data.collectedBy == request.auth.uid
        && (data.date is string || data.date is timestamp)
        && data.vendorName is string && data.vendorName.size() < 200
        && data.receiptId is string && data.receiptId.size() < 64
        && data.collectorName is string && data.collectorName.size() < 200
        && (data.get('notes', '') is string && data.get('notes', '').size() < 1000);
    }

    // --- Collections ---

    // Categories: Managed by Admins, Read by Staff
    match /categories/{categoryId} {
      allow read: if isStaff();
      allow create, update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    // Vendors: Created/Managed by Admins, Updated during payment by Staff
    match /vendors/{vendorId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidVendor(incoming());
      allow update: if isStaff() && isValidVendor(incoming()) && (
        isAdmin() || (
          // Action: Update Payment Totals
          incoming().diff(existing()).affectedKeys().hasOnly(['totalPaid', 'status', 'lastPaymentDate'])
        )
      );
      allow delete: if isAdmin();
    }

    // Workers: Assist staff
    match /workers/{workerId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidWorker(incoming());
      allow update: if isStaff() && (
        isAdmin() || (
          // Allow soft delete or updates if admin/staff
          isValidWorker(incoming()) &&
          (incoming().diff(existing()).affectedKeys().hasOnly(['deleted']) || isAdmin())
        )
      );
      allow delete: if isAdmin();
    }

    // Payments: Created by Staff, Immutable once written
    match /payments/{paymentId} {
      allow read: if isStaff();
      allow create: if isStaff() 
        && isValidId(paymentId)
        && isValidPayment(incoming())
        && exists(/databases/$(database)/documents/vendors/$(incoming().vendorId));
      allow update, delete: if isAdmin();
    }

    // Users: Profiles and roles
    match /users/{uid} {
      allow read: if isSignedIn();
      // Allow self-creation for registration
      allow create: if isSignedIn() && request.auth.uid == uid;
      // Only admins can change roles
      allow update: if isAdmin() || (request.auth.uid == uid && !incoming().diff(existing()).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }
  }
}
